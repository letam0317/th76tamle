# ============================================================================
#  FILE MẪU CẤU HÌNH — KHÔNG chứa thông tin thật, AN TOÀN để chia sẻ / lên git
# ----------------------------------------------------------------------------
#  CÁCH DÙNG:
#    1. Sao chép file này thành .env :  cp .env.example .env   (hoặc: npm run setup)
#    2. Mở .env và điền thông tin THẬT của bạn vào.
#    3. KHÔNG bao giờ commit file .env — nó đã được .gitignore chặn sẵn.
# ============================================================================

# --- Tài khoản đăng nhập WMS (Hasaki) ---
WMS_USERNAME=email@hasaki.vn
WMS_PASSWORD=

# Khoá bí mật 2FA (TOTP) — chuỗi base32 hiện trong Google Authenticator khi quét QR
# (KHÔNG phải mã 6 số; mã 6 số sẽ được crawler tự sinh ra từ khoá này).
WMS_2FA_SECRET=

# --- Cấu hình WMS (có giá trị mặc định trong code, chỉ đổi khi cần) ---
WMS_LOGIN_URL=https://wms.inshasaki.com/login
WMS_API_BASE=https://wms-gw.inshasaki.com/api
WMS_COMPANY_IDS=1001
# Endpoint dữ liệu kiểm kê SKU (đường dẫn sau /api). Đổi nếu bộ lọc khác.
WMS_DATA_PATH=/v1/wms/counting-plan/checklists/type-location
# Tham số lọc dạng query string (tuỳ chọn), ví dụ: warehouse_code=SHOP-170&status=ALL
WMS_DATA_QUERY=

# --- Google Sheets (đích đổ dữ liệu) ---
GOOGLE_SHEET_ID=1Vck9vJv8rvD2Nftd_eqstms98wbw6S4wHNUARAzpWbQ
# Tên tab sẽ ghi dữ liệu thô đã làm sạch vào (crawler tự tạo nếu chưa có)
GOOGLE_SHEET_TAB=RAW_WMS
# Đường dẫn tới file khoá Service Account (.json tải từ Google Cloud Console).
# Nhớ chia sẻ Google Sheet cho email service account với quyền Editor.
GOOGLE_CREDENTIALS_PATH=./credentials.json

# --- Tuỳ chọn vận hành ---
# true = chạy ẩn (không hiện cửa sổ trình duyệt); false = hiện để gỡ lỗi
HEADLESS=true
# Số lần thử lại khi mạng/đăng nhập lỗi
MAX_RETRIES=2

# ============================================================================
#  ĐẨY BÁO CÁO 5S → TASK WORKFLOW (push-5s-to-workflow.js)
# ============================================================================
# Mã bí mật bảo vệ endpoint Apps Script — PHẢI trùng biến SECRET trong google-script.gs
APPSCRIPT_KEY=
# (Tuỳ chọn) ghi đè cấu hình mặc định trong code nếu cần:
APPSCRIPT_URL=
WORKFLOW_ID=591
STAFF_ID=17312

# --- Đăng nhập work.hasaki.vn (login-hasaki.js tự điền email + mật khẩu) ---
HASAKI_EMAIL=
HASAKI_PASSWORD=
# Khoá bí mật 2FA (TOTP) của work.hasaki.vn — chuỗi BASE32 hiện khi quét QR trong
# Google/Microsoft Authenticator (KHÔNG phải mã 6 số). Điền vào đây thì login-hasaki.js
# TỰ SINH + ĐIỀN OTP 6 số → đăng nhập tự động 100% (không cần gõ tay).
# Bỏ trống = giữ chế độ cũ (người gõ OTP thủ công).
HASAKI_2FA_SECRET=
